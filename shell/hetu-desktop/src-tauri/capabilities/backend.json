{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "backend",
  "description": "允许 Tauri 启动 Hetu.Api 后端：sidecar 或开发期 dotnet 命令",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "Hetu.Api",
          "sidecar": true,
          "args": ["--urls", { "validator": "^http://127\\.0\\.0\\.1:\\d+$" }]
        },
        {
          "name": "dotnet",
          "cmd": "dotnet",
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "Hetu.Api",
          "sidecar": true,
          "args": ["--urls", { "validator": "^http://127\\.0\\.0\\.1:\\d+$" }]
        },
        {
          "name": "dotnet",
          "cmd": "dotnet",
          "args": true
        }
      ]
    },
    "shell:allow-kill"
  ]
}
